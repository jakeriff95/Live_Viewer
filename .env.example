PORT=3000

# ADS-B provider options: opensky | demo
ADSB_PROVIDER=opensky
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# AIS provider options: aisstream | demo
AIS_PROVIDER=demo
AISSTREAM_API_KEY=

# Optional. When using AISStream, the backend will re-subscribe to the most recent map viewport.
# If you want to pin a starting bbox before the first viewport request, use west,south,east,north
AISSTREAM_INITIAL_BBOX=-180,-85,180,85

# Poll interval hints (milliseconds)
ADSB_CACHE_TTL_MS=8000
AIS_CACHE_TTL_MS=8000
